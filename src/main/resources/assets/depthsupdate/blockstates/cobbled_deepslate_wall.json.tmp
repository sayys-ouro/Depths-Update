{
  "multipart": [
    {
      "apply": {
        "model": "depthsupdate:cobbled_deepslate_wall_post"
      },,
  "variants": { "inventory": { "model": "depthsupdate:cobbled_deepslate_wall_inventory" } }
      "when": {
        "up": "true"
      }
    },
    {
      "apply": {
        "model": "depthsupdate:cobbled_deepslate_wall_side",
        "uvlock": true
      },
      "when": {
        "north": "true"
      }
    },
    {
      "apply": {
        "model": "depthsupdate:cobbled_deepslate_wall_side",
        "uvlock": true,
        "y": 90
      },
      "when": {
        "east": "true"
      }
    },
    {
      "apply": {
        "model": "depthsupdate:cobbled_deepslate_wall_side",
        "uvlock": true,
        "y": 180
      },
      "when": {
        "south": "true"
      }
    },
    {
      "apply": {
        "model": "depthsupdate:cobbled_deepslate_wall_side",
        "uvlock": true,
        "y": 270
      },
      "when": {
        "west": "true"
      }
    }
  ]
}
